---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
}

const { title, description, date, tags } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(date);
---
<BaseLayout title={title} description={description}>
  <div class="post-wrapper">
    <a href="/thinking-out-loud" class="post-back">&larr; Thinking Out Loud</a>

    <header class="post-header">
      <h1 class="post-header__title">{title}</h1>
      <time class="post-header__date" datetime={date.toISOString().slice(0, 10)}>
        {formattedDate}
      </time>
      {tags.length > 0 && (
        <ul class="post-header__tags">
          {tags.map(tag => <li>{tag}</li>)}
        </ul>
      )}
    </header>

    <article class="post-body">
      <slot />
    </article>

    <a href="/thinking-out-loud" class="post-back post-back--bottom">&larr; Thinking Out Loud</a>
  </div>
</BaseLayout>

<style>
  .post-wrapper {
    max-width: var(--reading-width);
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 5rem) 1.5rem;
  }

  .post-back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--rust);
    text-decoration: none;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
  }

  .post-back:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .post-back--bottom {
    margin-top: 3.5rem;
    margin-bottom: 0;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(28, 28, 28, 0.12);
  }

  .post-header__title {
    font-size: clamp(1.9rem, 5vw, 3rem);
    margin-bottom: 1rem;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .post-header__date {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--rust);
    letter-spacing: 0.06em;
  }

  .post-header__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
  }

  .post-header__tags li {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 0.2rem 0.6rem;
    background: rgba(28, 28, 28, 0.07);
    border-radius: 2px;
    letter-spacing: 0.06em;
    color: var(--mid-grey);
  }

  .post-body :global(p) {
    margin-bottom: 1.4em;
  }

  .post-body :global(h2) {
    font-size: 1.6rem;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
  }

  .post-body :global(h3) {
    font-size: 1.25rem;
    margin-top: 2em;
    margin-bottom: 0.5em;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--rust);
    margin: 2em 0;
    padding: 0.5em 1.5em;
    color: var(--mid-grey);
    font-style: italic;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.4em;
  }

  .post-body :global(li) {
    margin-bottom: 0.4em;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(28, 28, 28, 0.12);
    margin: 2.5em 0;
  }
</style>
