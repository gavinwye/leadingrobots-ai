---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

const allPosts = await getCollection('thinking-out-loud', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const posts = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---
<BaseLayout
  title="Thinking Out Loud"
  description="Notes from writing Leading Robots: The AI Organisation — ideas, half-formed thinking, and things worth working through in public."
>
  <div class="writing-index">
    <header class="writing-index__header">
      <a href="/" class="writing-index__back">&larr; Home</a>
      <h1>Thinking Out Loud</h1>
      <p>
        Notes from writing <em>Leading Robots: The AI Organisation</em> &mdash; ideas,
        half-formed thinking, and things worth working through in public.
      </p>
    </header>

    <div class="writing-index__posts">
      {posts.length > 0 ? (
        posts.map(post => (
          <PostCard
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            slug={post.slug}
          />
        ))
      ) : (
        <p class="writing-index__empty">First notes coming soon.</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .writing-index {
    max-width: var(--reading-width);
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 5rem) 1.5rem;
  }

  .writing-index__header {
    margin-bottom: 3.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(28, 28, 28, 0.12);
  }

  .writing-index__back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--rust);
    text-decoration: none;
    text-transform: uppercase;
    margin-bottom: 1.75rem;
  }

  .writing-index__back:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .writing-index__header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .writing-index__header p {
    color: var(--mid-grey);
    font-size: 1rem;
    margin: 0;
    max-width: 48ch;
    line-height: 1.65;
  }

  .writing-index__posts {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .writing-index__empty {
    color: var(--mid-grey);
    font-style: italic;
  }
</style>
