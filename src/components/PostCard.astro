---
interface Props {
  title: string;
  date: Date;
  description: string;
  slug: string;
}

const { title, date, description, slug } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(date);
---
<article class="post-card">
  <time class="post-card__date" datetime={date.toISOString().slice(0, 10)}>
    {formattedDate}
  </time>
  <h2 class="post-card__title">
    <a href={`/thinking-out-loud/${slug}`}>{title}</a>
  </h2>
  <p class="post-card__description">{description}</p>
</article>

<style>
  .post-card {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(28, 28, 28, 0.1);
  }

  .post-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .post-card__date {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--mid-grey);
    letter-spacing: 0.06em;
    margin-bottom: 0.6rem;
  }

  .post-card__title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    margin-bottom: 0.6rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .post-card__title a {
    color: var(--charcoal);
    text-decoration: none;
  }

  .post-card__title a:hover {
    color: var(--rust);
  }

  .post-card__description {
    font-size: 0.95rem;
    color: var(--charcoal);
    opacity: 0.7;
    margin: 0;
    line-height: 1.65;
  }
</style>
